-        return input_path;
+    try {
+        std::filesystem::path path(input_path);
+
+        /*
+         * DATA_DIR is compiled as ../share for portable Windows packages.
+         * Resolve that specific resource path relative to the executable,
+         * not relative to the caller's current working directory.
+         */
+        if (path.is_relative() && isPortableDataPath(input_path)) {
+            return absoluteWindowsPath(executableDirectory() / path);
